<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ═══ Identity ═══════════════════════════════════════════════════════════ -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Your Name</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="AI Translator" />
  <Description DefaultValue="Translate email body to the recipient's language using Claude AI." />

  <!-- Icon URLs — replace gipper65 in all lines below -->
  <IconUrl DefaultValue="https://gipper65.github.io/outlook-translator/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://gipper65.github.io/outlook-translator/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://github.com/gipper65/outlook-translator" />

  <!-- ═══ Permissions ══════════════════════════════════════════════════════════ -->
  <Permissions>ReadWriteItem</Permissions>

  <!-- ═══ Host rules — Outlook only ══════════════════════════════════════════ -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <!-- ═══ Version Overrides (ribbon button) ═══════════════════════════════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.3">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>

            <!-- Taskpane function file -->
            <FunctionFile resid="Commands.Url" />

            <!-- ── Compose toolbar extension point ── -->
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup">
                  <Label resid="GroupLabel" />

                  <!-- Translate button -->
                  <Control xsi:type="Button" id="translateButton">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>ButtonId1</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>

                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <!-- ═══ Resources — replace gipper65 in all URLs ═══════════ -->
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://gipper65.github.io/outlook-translator/assets/icon-16.png" />
          <bt:Image id="Icon.32x32" DefaultValue="https://gipper65.github.io/outlook-translator/assets/icon-32.png" />
          <bt:Image id="Icon.80x80" DefaultValue="https://gipper65.github.io/outlook-translator/assets/icon-80.png" />
        </bt:Images>

        <bt:Urls>
          <bt:Url id="Commands.Url"   DefaultValue="https://gipper65.github.io/outlook-translator/taskpane.html" />
          <bt:Url id="Taskpane.Url"   DefaultValue="https://gipper65.github.io/outlook-translator/taskpane.html" />
        </bt:Urls>

        <bt:ShortStrings>
          <bt:String id="GroupLabel"            DefaultValue="AI Tools" />
          <bt:String id="TaskpaneButton.Label"  DefaultValue="🌐 Translate" />
        </bt:ShortStrings>

        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Auto-detect recipient language and translate this email using Claude AI." />
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
